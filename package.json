{
  "name": "telepath",
  "version": "1.0.0",
  "description": "Telegram chatbot powered by LLM (Ollama, OpenAI, Claude, Gemini)",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:electron": "tsc -p tsconfig.electron.json && node scripts/copy-renderer.js && electron dist-electron/main.cjs",
    "build": "tsc",
    "build:electron": "tsc -p tsconfig.electron.json && node scripts/copy-renderer.js",
    "pack": "rm -rf release && npm run build && npm run build:electron && node scripts/prepare-app.cjs && npx electron-builder --dir",
    "dist": "rm -rf release && npm run build && npm run build:electron && node scripts/prepare-app.cjs && npx electron-builder",
    "start": "node dist/index.js",
    "start:electron": "electron dist-electron/main.cjs",
    "webhook:delete": "tsx scripts/delete-webhook.ts",
    "claude:test": "tsx scripts/test-claude-key.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "grammy": "^1.35.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^24.6.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "com.novaassit.telepath",
    "productName": "Telepath",
    "asar": false,
    "afterPack": "./scripts/after-pack.cjs",
    "directories": {
      "output": "release",
      "app": "app-build"
    },
    "extraResources": [
      {
        "from": ".env.example",
        "to": ".env.example"
      },
      {
        "from": "dist",
        "to": "bot/dist"
      },
      {
        "from": "node_modules",
        "to": "bot/node_modules"
      },
      {
        "from": "package.json",
        "to": "bot/package.json"
      }
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
