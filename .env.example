# 필수: 텔레그램 봇 토큰 (BotFather 발급)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# LLM 프로바이더: ollama | openai | custom | claude | gemini
LLM_PROVIDER=ollama

# ---- Ollama (LLM_PROVIDER=ollama) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ---- OpenAI (LLM_PROVIDER=openai) ----
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ---- Custom · OpenAI 호환 API (LLM_PROVIDER=custom) ----
CUSTOM_LLM_BASE_URL=https://your-openai-compatible-api.com/v1
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=gpt-4o

# ---- Claude / Anthropic (LLM_PROVIDER=claude) ----
# 모델 예: claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MAX_TOKENS=8192

# ---- Gemini / Google AI (LLM_PROVIDER=gemini) ----
# 모델 예: gemini-2.5-flash, gemini-2.5-pro, gemini-3-flash-preview
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_MAX_TOKENS=8192

# 공통
SYSTEM_PROMPT=You are a helpful assistant.
MAX_HISTORY_MESSAGES=20
MAX_INPUT_LENGTH=10000
